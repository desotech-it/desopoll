[
  {
    "op": "add",
    "path": "/spec/listeners/-",
    "value": {
      "name": "http-poll",
      "protocol": "HTTP",
      "port": 80,
      "hostname": "poll.deso.tech",
      "allowedRoutes": {
        "namespaces": {
          "from": "Selector",
          "selector": { "matchLabels": { "kubernetes.io/metadata.name": "desopoll" } }
        }
      }
    }
  }
]
